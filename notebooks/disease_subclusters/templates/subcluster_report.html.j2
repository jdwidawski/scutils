<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Disease Subcluster Report — {{ tissue }}</title>

  <style>
    /* ── Reset & base ── */
    *, *::before, *::after { box-sizing: border-box; }
    html, body { height: 100%; margin: 0; padding: 0; }
    body {
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
      background: #f4f6f8;
      color: #1a1a2e;
      display: flex;
      flex-direction: column;
    }

    /* ── Sticky top header ── */
    .page-header {
      background: #1a1a2e;
      color: #fff;
      padding: 14px 24px;
      flex-shrink: 0;
      position: sticky;
      top: 0;
      z-index: 100;
    }
    .page-header h1 { margin: 0 0 2px; font-size: 1.2rem; }
    .page-header p  { margin: 0; opacity: 0.65; font-size: 0.82rem; }

    /* ── Two-column layout ── */
    .layout {
      display: flex;
      flex: 1;
      overflow: hidden;
      height: calc(100vh - 60px);
    }

    /* ── Sidebar ── */
    .sidebar {
      width: 20%;
      min-width: 180px;
      max-width: 280px;
      background: #fff;
      border-right: 1px solid #dde2ea;
      display: flex;
      flex-direction: column;
      overflow: hidden;
      flex-shrink: 0;
    }
    .sidebar-title {
      background: #f0f2f5;
      padding: 10px 14px;
      font-size: 0.72rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: .07em;
      color: #4a90d9;
      border-bottom: 1px solid #dde2ea;
      flex-shrink: 0;
    }
    .sidebar-search {
      padding: 8px 10px;
      border-bottom: 1px solid #edf0f4;
      flex-shrink: 0;
    }
    .sidebar-search input {
      width: 100%;
      padding: 5px 8px;
      border: 1px solid #dde2ea;
      border-radius: 4px;
      font-size: 0.8rem;
      outline: none;
    }
    .sidebar-search input:focus { border-color: #4a90d9; }
    .sidebar-list { overflow-y: auto; flex: 1; }
    .sidebar-item {
      padding: 9px 14px;
      cursor: pointer;
      font-size: 0.82rem;
      border-bottom: 1px solid #f0f2f5;
      line-height: 1.35;
      transition: background .12s;
    }
    .sidebar-item:hover { background: #f4f6f8; }
    .sidebar-item.active {
      background: #e8f0fb;
      border-left: 3px solid #4a90d9;
      font-weight: 600;
      color: #1a5aa8;
    }
    .sidebar-item .sc-label { word-break: break-word; }
    .sidebar-item .sc-badge {
      display: inline-block;
      background: #4a90d9;
      color: #fff;
      border-radius: 10px;
      font-size: 0.65rem;
      padding: 1px 7px;
      margin-top: 3px;
    }

    /* ── Main panel ── */
    .main-content {
      flex: 1;
      overflow-y: auto;
      padding: 24px 32px 60px;
    }

    /* ── One subcluster visible at a time ── */
    .sc-section { display: none; }
    .sc-section.visible { display: block; }

    /* ── Section header ── */
    .sc-header {
      background: #1a1a2e;
      color: #fff;
      padding: 12px 20px;
      border-radius: 6px 6px 0 0;
      display: flex;
      align-items: center;
    }
    .sc-header h2 { margin: 0; font-size: 1rem; letter-spacing: .02em; }
    .sc-header .badge {
      background: #4a90d9;
      border-radius: 12px;
      font-size: 0.75rem;
      padding: 2px 10px;
      margin-left: 10px;
    }
    .sc-body {
      background: #fff;
      border: 1px solid #e4e8ee;
      border-top: none;
      border-radius: 0 0 6px 6px;
      padding: 22px;
    }

    /* ── Stats grid ── */
    .stats-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(170px, 1fr));
      gap: 10px;
      margin-bottom: 22px;
    }
    .stat-box { background: #f8f9fb; border: 1px solid #e4e8ee; border-radius: 4px; padding: 9px 12px; }
    .stat-box .label { font-size: 0.7rem; color: #888; text-transform: uppercase; letter-spacing: .05em; }
    .stat-box .value { font-size: 1.05rem; font-weight: 600; margin-top: 2px; word-break: break-word; }

    /* ── Disease breakdown table ── */
    .breakdown-table { width: 100%; border-collapse: collapse; font-size: 0.85rem; margin-bottom: 22px; }
    .breakdown-table th { background: #f0f2f5; text-align: left; padding: 7px 12px; border-bottom: 2px solid #dde2ea; }
    .breakdown-table td { padding: 6px 12px; border-bottom: 1px solid #edf0f4; }
    .breakdown-table tr:last-child td { border-bottom: none; }

    /* ── Section labels ── */
    .section-label {
      font-size: 0.75rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: .08em;
      color: #4a90d9;
      margin: 20px 0 10px;
      border-bottom: 1px solid #e4e8ee;
      padding-bottom: 4px;
    }

    /* ── Image grid ── */
    .img-grid { display: grid; gap: 14px; margin-bottom: 20px; align-items: stretch; }
    .img-grid.cols-3 { grid-template-columns: repeat(3, 1fr); }
    .img-grid.cols-2 { grid-template-columns: repeat(2, 1fr); }
    .img-card { border: 1px solid #e4e8ee; border-radius: 4px; overflow: hidden;
                display: flex; flex-direction: column; }
    .img-card .img-title {
      background: #f8f9fb;
      font-size: 0.75rem;
      font-weight: 600;
      padding: 6px 10px;
      border-bottom: 1px solid #e4e8ee;
      display: flex;
      justify-content: space-between;
      align-items: center;
      flex-shrink: 0;
    }
    /* UMAP grid: all three cards share the same height; image centred inside */
    .img-grid.cols-3 .img-card { height: 100%; }
    .img-grid.cols-3 .img-card .img-body {
      flex: 1;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 6px;
      background: #fff;
    }
    .img-grid.cols-3 .img-card img {
      width: auto;
      height: auto;
      max-width: 100%;
      max-height: 100%;
      object-fit: contain;
      display: block;
    }
    /* Non-UMAP grids (cols-2): full-width image, no fixed height */
    .img-card img { width: 100%; display: block; }
    .download-link { color: #4a90d9; font-size: 0.7rem; text-decoration: none; }
    .download-link:hover { text-decoration: underline; }

    /* ── DE table ── */
    .de-search { width: 100%; max-width: 320px; margin: 10px 0 4px; padding: 5px 10px; border: 1px solid #d0d5dd; border-radius: 6px; font-size: 0.85rem; }
    .de-table-wrapper { overflow-x: auto; margin-top: 8px; min-height: 80px; }
    table.de-table { width: 100%; border-collapse: collapse; font-size: 0.82rem; }
    table.de-table thead th {
      background: #f0f2f5; text-align: left; padding: 6px 10px;
      border-bottom: 2px solid #dde2ea; cursor: pointer;
      white-space: nowrap; user-select: none;
    }
    table.de-table thead th:hover { background: #e4e8ee; }
    table.de-table tbody td { padding: 5px 10px; border-bottom: 1px solid #f0f2f5; font-size: 0.80rem; }
    table.de-table tbody tr:last-child td { border-bottom: none; }
    .sort-arrow { color: #4a90d9; margin-left: 4px; font-size: 0.7rem; }
    .de-controls {
      display: flex; justify-content: space-between; align-items: center;
      margin-top: 8px; font-size: 0.8rem; color: #555;
    }
    .de-pager button {
      background: #f0f2f5; border: 1px solid #dde2ea; border-radius: 3px;
      padding: 3px 10px; cursor: pointer; font-size: 0.78rem;
    }
    .de-pager button:disabled { opacity: 0.4; cursor: default; }
    .de-pager button:not(:disabled):hover { background: #e4e8ee; }
    .de-pager .de-pageinfo { margin: 0 8px; }
    .de-loading { color: #aaa; font-size: 0.85rem; padding: 12px 0; }

    /* ── Empty state ── */
    .empty-state { color: #aaa; font-size: 0.9rem; text-align: center; padding: 60px 20px; }
    .empty-state .icon { font-size: 2.5rem; margin-bottom: 12px; }

    /* ── Responsive ── */
    @media (max-width: 900px) {
      .layout { flex-direction: column; height: auto; }
      .sidebar { width: 100%; max-width: 100%; height: auto; border-right: none; border-bottom: 1px solid #dde2ea; }
      .sidebar-list { max-height: 220px; }
      .main-content { padding: 16px; }
      .img-grid.cols-3 { grid-template-columns: 1fr 1fr; }
    }
    @media (max-width: 600px) {
      .img-grid.cols-3, .img-grid.cols-2 { grid-template-columns: 1fr; }
    }
  </style>
</head>
<body>

<!-- ── Sticky top header ─────────────────────────────────────────────── -->
<div class="page-header">
  <h1>Disease Subcluster Report — {{ tissue }}</h1>
  <p>{{ subclusters | length }} subcluster(s) &nbsp;·&nbsp; Generated {{ generated_at }}</p>
</div>

<!-- ── Two-column layout ─────────────────────────────────────────────── -->
<div class="layout">

  <!-- Sidebar: searchable subcluster list -->
  <nav class="sidebar">
    <div class="sidebar-title">Subclusters</div>
    <div class="sidebar-search">
      <input type="text" id="sidebar-filter" placeholder="Filter subclusters…"
             oninput="filterSidebar(this.value)" />
    </div>
    <div class="sidebar-list" id="sidebar-list">
      {% for sc in subclusters %}
      <div class="sidebar-item" data-target="{{ sc.anchor }}"
           onclick="showSubcluster('{{ sc.anchor }}', this)">
        <div class="sc-label">{{ sc.label }}</div>
        <span class="sc-badge">{{ sc.disease }}</span>
      </div>
      {% endfor %}
    </div>
  </nav>

  <!-- Main panel: one subcluster at a time -->
  <div class="main-content" id="main-content">

    <div id="empty-state" class="empty-state">
      <div class="icon">🔬</div>
      <div>Select a subcluster from the panel on the left to view its details.</div>
    </div>

    {% for sc in subclusters %}
    <div class="sc-section" id="sc-{{ sc.anchor }}">
      <div class="sc-header">
        <h2>{{ sc.label }} <span class="badge">{{ sc.disease }}</span></h2>
      </div>
      <div class="sc-body">

        <!-- Stats -->
        <div class="section-label">Summary statistics</div>
        <div class="stats-grid">
          <div class="stat-box">
            <div class="label">Total cells</div>
            <div class="value">{{ sc.stats.n_total }}</div>
          </div>
          <div class="stat-box">
            <div class="label">Disease cells</div>
            <div class="value">{{ sc.stats.n_disease }}</div>
          </div>
          <div class="stat-box">
            <div class="label">Healthy cells</div>
            <div class="value">{{ sc.stats.n_healthy }}</div>
          </div>
          <div class="stat-box">
            <div class="label">Fold enrichment</div>
            <div class="value">{{ sc.stats.fold_enrichment }}</div>
          </div>
          <div class="stat-box">
            <div class="label">FDR p-value</div>
            <div class="value">{{ sc.stats.fdr_pval }}</div>
          </div>
          <div class="stat-box">
            <div class="label">Cell type</div>
            <div class="value">{{ sc.stats.cell_type }}</div>
          </div>
          <div class="stat-box" style="grid-column: 1 / -1;">
            <div class="label">Disease composition</div>
            <div class="value" style="font-size:0.82rem;">{{ sc.stats.disease_composition }}</div>
          </div>
          <div class="stat-box" style="grid-column: 1 / -1;">
            <div class="label">Differential expression reference</div>
            <div class="value" style="font-size:0.82rem;">{{ sc.stats.de_reference }}</div>
          </div>
        </div>

        <!-- Per-disease breakdown -->
        {% if sc.disease_breakdown %}
        <div class="section-label">Per-disease breakdown</div>
        <table class="breakdown-table">
          <thead>
            <tr>
              <th>Disease</th>
              <th>Cells in subcluster</th>
              <th>% of subcluster</th>
              <th>Fold enrichment</th>
              <th>p-value</th>
              <th>FDR</th>
            </tr>
          </thead>
          <tbody>
            {% for row in sc.disease_breakdown %}
            <tr>
              <td>{{ row.disease }}</td>
              <td>{{ row.n_cells }}</td>
              <td>{{ row.pct }}</td>
              <td>{{ row.fold }}</td>
              <td>{{ row.pval }}</td>
              <td>{{ row.fdr }}</td>
            </tr>
            {% endfor %}
          </tbody>
        </table>
        {% endif %}

        <!-- UMAP panels — images are separate files in img/ -->
        <div class="section-label">UMAP embeddings</div>
        <div class="img-grid cols-3">
          {% if sc.umap_celltype_path %}
          <div class="img-card">
            <div class="img-title">
              Cell type
              <a class="download-link" href="{{ sc.umap_celltype_path | urlencode_path }}" download="{{ sc.anchor }}_umap_celltype.png">⬇ download</a>
            </div>
            <div class="img-body">
              <img src="{{ sc.umap_celltype_path | urlencode_path }}" alt="UMAP cell type" />
            </div>
          </div>
          {% endif %}
          {% if sc.umap_disease_path %}
          <div class="img-card">
            <div class="img-title">
              Disease condition
              <a class="download-link" href="{{ sc.umap_disease_path | urlencode_path }}" download="{{ sc.anchor }}_umap_disease.png">⬇ download</a>
            </div>
            <div class="img-body">
              <img src="{{ sc.umap_disease_path | urlencode_path }}" alt="UMAP disease" />
            </div>
          </div>
          {% endif %}
          {% if sc.umap_highlight_path %}
          <div class="img-card">
            <div class="img-title">
              Subcluster highlight
              <a class="download-link" href="{{ sc.umap_highlight_path | urlencode_path }}" download="{{ sc.anchor }}_umap_highlight.png">⬇ download</a>
            </div>
            <div class="img-body">
              <img src="{{ sc.umap_highlight_path | urlencode_path }}" alt="UMAP highlight" />
            </div>
          </div>
          {% endif %}
        </div>

        <!-- Volcano + Dotplot -->
        <div class="section-label">Differential expression &amp; functional enrichment</div>
        <div class="img-grid cols-2">
          {% if sc.volcano_path %}
          <div class="img-card">
            <div class="img-title">
              Volcano plot
              <a class="download-link" href="{{ sc.volcano_path | urlencode_path }}" download="{{ sc.anchor }}_volcano.png">⬇ download</a>
            </div>
            <img src="{{ sc.volcano_path | urlencode_path }}" alt="Volcano plot" />
          </div>
          {% endif %}
          {% if sc.dotplot_path %}
          <div class="img-card">
            <div class="img-title">
              Functional enrichment
              <a class="download-link" href="{{ sc.dotplot_path | urlencode_path }}" download="{{ sc.anchor }}_enrichment.png">⬇ download</a>
            </div>
            <img src="{{ sc.dotplot_path | urlencode_path }}" alt="Enrichment dotplot" />
          </div>
          {% endif %}
        </div>

        <!-- DE table: built lazily from embedded JSON on first selection -->
        {% if sc.de_json %}
        <div class="section-label" style="display:flex; justify-content:space-between; align-items:center;">
          <span>Significant DE genes (padj &lt; threshold)</span>
          {% if sc.de_csv_path %}<a class="download-link" href="{{ sc.de_csv_path | urlencode_path }}" download="{{ sc.anchor }}_de.csv">⬇ download CSV</a>{% endif %}
        </div>
        <input type="search" class="de-search" placeholder="Search gene…" oninput="_searchDE('{{ sc.anchor }}', this.value)">
        <div class="de-table-wrapper">
          <p class="de-loading" id="de-loading-{{ sc.anchor }}">Loading…</p>
          <table id="de-{{ sc.anchor }}" class="de-table" style="display:none">
            <thead><tr></tr></thead>
            <tbody></tbody>
          </table>
          <div class="de-controls" id="de-controls-{{ sc.anchor }}" style="display:none">
            <span id="de-info-{{ sc.anchor }}"></span>
            <div class="de-pager" id="de-pager-{{ sc.anchor }}">
              <button class="de-prev" onclick="_deTables['{{ sc.anchor }}'].changePage(-1)">‹ Prev</button>
              <span class="de-pageinfo" id="de-pageinfo-{{ sc.anchor }}"></span>
              <button class="de-next" onclick="_deTables['{{ sc.anchor }}'].changePage(1)">Next ›</button>
            </div>
          </div>
        </div>
        <script type="application/json" id="de-data-{{ sc.anchor }}">{{ sc.de_json }}</script>
        {% else %}
        <p style="color:#888; font-size:0.85rem; margin-top:16px;">
          No significant DE results available for this subcluster.
        </p>
        {% endif %}

      </div><!-- /sc-body -->
    </div><!-- /sc-section -->
    {% endfor %}

  </div><!-- /main-content -->
</div><!-- /layout -->

<script>
  // ── Pure-JS DE table (no external dependencies, works from file://) ────────
  var _deTables = {};

  function _initDETable(anchor) {
    if (_deTables[anchor]) return;
    var dataEl = document.getElementById('de-data-' + anchor);
    if (!dataEl) return;
    var payload;
    try { payload = JSON.parse(dataEl.textContent); } catch(e) { return; }
    var cols = payload.columns || [], allRows = payload.data || [];
    if (!cols.length) return;

    var PER_PAGE = 20;
    var lfcI = -1, pvalI = -1;
    cols.forEach(function(c, i) {
      if (c === 'log2FoldChange' || c === 'logfoldchanges') lfcI = i;
      if (c === 'padj' || c === 'pvals_adj' || c === 'pvalue' || c === 'pvals') pvalI = i;
    });
    // Default sort: LFC descending (most upregulated first)
    var state = {
      sortCol: lfcI >= 0 ? lfcI : (pvalI >= 0 ? pvalI : -1),
      sortDir: lfcI >= 0 ? -1 : 1,
      page: 0,
      query: ''
    };

    function cmp(a, b, dir) {
      if (a === null || a === '' || a === undefined) return 1;
      if (b === null || b === '' || b === undefined) return -1;
      var an = parseFloat(a), bn = parseFloat(b);
      if (!isNaN(an) && !isNaN(bn)) return dir * (an - bn);
      return dir * String(a).localeCompare(String(b));
    }
    function getFiltered() {
      if (!state.query) return allRows;
      var q = state.query.toLowerCase();
      return allRows.filter(function(r) {
        return r.some(function(v) { return String(v == null ? '' : v).toLowerCase().indexOf(q) >= 0; });
      });
    }
    function getSorted() {
      var filtered = getFiltered();
      if (state.sortCol < 0) return filtered;
      var sc = state.sortCol, sd = state.sortDir;
      return filtered.slice().sort(function(a, b) { return cmp(a[sc], b[sc], sd); });
    }
    function esc(v) {
      return (v === null || v === undefined ? '' : String(v))
        .replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
    }

    function render() {
      var rows = getSorted();
      var total = rows.length;
      var maxPage = Math.max(0, Math.ceil(total / PER_PAGE) - 1);
      if (state.page > maxPage) state.page = maxPage;
      var slice = rows.slice(state.page * PER_PAGE, (state.page + 1) * PER_PAGE);

      var tbl = document.getElementById('de-' + anchor);
      // Header
      tbl.querySelector('thead tr').innerHTML = cols.map(function(c, i) {
        var arrow = state.sortCol === i ? (state.sortDir > 0 ? ' ▲' : ' ▼') : ' ⇅';
        return '<th onclick="_deTables[\''+anchor+'\'].sortBy('+i+')">' +
               esc(c) + '<span class="sort-arrow">'+arrow+'</span></th>';
      }).join('');
      // Body
      tbl.querySelector('tbody').innerHTML = slice.map(function(r) {
        return '<tr>' + r.map(function(v) { return '<td>' + esc(v) + '</td>'; }).join('') + '</tr>';
      }).join('');

      // Info
      var infoEl = document.getElementById('de-info-' + anchor);
      if (infoEl) infoEl.textContent = total ?
        'Showing ' + (state.page * PER_PAGE + 1) + '–' +
        Math.min((state.page + 1) * PER_PAGE, total) + ' of ' + total + ' genes' : '0 genes';
      var pinfoEl = document.getElementById('de-pageinfo-' + anchor);
      if (pinfoEl) pinfoEl.textContent = 'Page ' + (state.page + 1) + ' / ' + (maxPage + 1);
      // Pager buttons
      var pager = document.getElementById('de-pager-' + anchor);
      if (pager) {
        pager.querySelector('.de-prev').disabled = (state.page === 0);
        pager.querySelector('.de-next').disabled = (state.page >= maxPage);
      }

      tbl.style.display = '';
      document.getElementById('de-controls-' + anchor).style.display = '';
      var loading = document.getElementById('de-loading-' + anchor);
      if (loading) loading.style.display = 'none';
    }

    _deTables[anchor] = {
      sortBy: function(ci) {
        if (state.sortCol === ci) { state.sortDir *= -1; }
        else { state.sortCol = ci; state.sortDir = 1; }
        state.page = 0; render();
      },
      changePage: function(delta) {
        var maxPage = Math.max(0, Math.ceil(getFiltered().length / PER_PAGE) - 1);
        state.page = Math.max(0, Math.min(state.page + delta, maxPage));
        render();
      },
      setQuery: function(q) {
        state.query = q;
        state.page = 0;
        render();
      }
    };
    render();
  }

  // ── Navigation ─────────────────────────────────────────────────────────
  function showSubcluster(anchor, el) {
    document.querySelectorAll('.sc-section').forEach(function(s) {
      s.classList.remove('visible');
    });
    var section = document.getElementById('sc-' + anchor);
    if (section) section.classList.add('visible');

    document.querySelectorAll('.sidebar-item').forEach(function(i) {
      i.classList.remove('active');
    });
    if (el) el.classList.add('active');

    document.getElementById('empty-state').style.display = 'none';
    document.getElementById('main-content').scrollTop = 0;

    // Initialise DE table lazily (element is visible so layout is correct)
    _initDETable(anchor);
  }

  function filterSidebar(query) {
    var q = query.toLowerCase();
    document.querySelectorAll('.sidebar-item').forEach(function(item) {
      item.style.display = item.textContent.toLowerCase().includes(q) ? '' : 'none';
    });
  }

  // ── Gene search ─────────────────────────────────────────────────────────
  function _searchDE(anchor, query) {
    var tbl = _deTables[anchor];
    if (!tbl) return;
    tbl.setQuery(query || '');
  }

  // Auto-select first subcluster
  (function() {
    var first = document.querySelector('.sidebar-item');
    if (first) first.click();
  })();
</script>
</body>
</html>

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Disease Subcluster Report — {{ tissue }}</title>

  <!-- DataTables CSS (inlined) -->
  <style>
{{ datatables_css }}
  </style>

  <style>
    /* ── Page ── */
    *, *::before, *::after { box-sizing: border-box; }
    body {
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
      background: #f4f6f8;
      color: #1a1a2e;
      margin: 0;
      padding: 0 0 60px;
    }

    /* ── Header ── */
    .page-header {
      background: #1a1a2e;
      color: #fff;
      padding: 28px 40px;
    }
    .page-header h1 { margin: 0 0 4px; font-size: 1.6rem; }
    .page-header p  { margin: 0; opacity: 0.65; font-size: 0.9rem; }

    /* ── TOC ── */
    .toc {
      background: #fff;
      border-left: 4px solid #4a90d9;
      margin: 28px 40px 0;
      padding: 16px 24px;
      border-radius: 4px;
      box-shadow: 0 1px 4px rgba(0,0,0,.08);
    }
    .toc h2 { margin: 0 0 10px; font-size: 1rem; color: #4a90d9; }
    .toc ol { margin: 0; padding-left: 20px; line-height: 1.8; }
    .toc a  { color: #4a90d9; text-decoration: none; }
    .toc a:hover { text-decoration: underline; }

    /* ── Card ── */
    .card {
      background: #fff;
      border-radius: 6px;
      box-shadow: 0 1px 4px rgba(0,0,0,.09);
      margin: 24px 40px 0;
      overflow: hidden;
    }
    .card-header {
      background: #1a1a2e;
      color: #fff;
      padding: 14px 22px;
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: space-between;
      user-select: none;
    }
    .card-header h2 { margin: 0; font-size: 1rem; letter-spacing: .02em; }
    .card-header .badge {
      background: #4a90d9;
      border-radius: 12px;
      font-size: 0.75rem;
      padding: 2px 10px;
      margin-left: 10px;
    }
    .card-header .chevron { transition: transform .2s; font-size: 1.1rem; }
    .card-header.collapsed .chevron { transform: rotate(-90deg); }
    .card-body { padding: 22px; }
    .card-body.hidden { display: none; }

    /* ── Stats table ── */
    .stats-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
      gap: 12px;
      margin-bottom: 22px;
    }
    .stat-box {
      background: #f8f9fb;
      border: 1px solid #e4e8ee;
      border-radius: 4px;
      padding: 10px 14px;
    }
    .stat-box .label { font-size: 0.72rem; color: #888; text-transform: uppercase; letter-spacing: .05em; }
    .stat-box .value { font-size: 1.15rem; font-weight: 600; margin-top: 2px; }

    /* ── Disease breakdown table ── */
    .breakdown-table {
      width: 100%;
      border-collapse: collapse;
      font-size: 0.85rem;
      margin-bottom: 22px;
    }
    .breakdown-table th {
      background: #f0f2f5;
      text-align: left;
      padding: 7px 12px;
      border-bottom: 2px solid #dde2ea;
    }
    .breakdown-table td {
      padding: 6px 12px;
      border-bottom: 1px solid #edf0f4;
    }
    .breakdown-table tr:last-child td { border-bottom: none; }

    /* ── Section labels ── */
    .section-label {
      font-size: 0.75rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: .08em;
      color: #4a90d9;
      margin: 20px 0 10px;
      border-bottom: 1px solid #e4e8ee;
      padding-bottom: 4px;
    }

    /* ── Image grid ── */
    .img-grid {
      display: grid;
      gap: 14px;
      margin-bottom: 20px;
    }
    .img-grid.cols-3 { grid-template-columns: repeat(3, 1fr); }
    .img-grid.cols-2 { grid-template-columns: repeat(2, 1fr); }
    .img-grid.cols-1 { grid-template-columns: 1fr; }
    .img-card {
      border: 1px solid #e4e8ee;
      border-radius: 4px;
      overflow: hidden;
    }
    .img-card .img-title {
      background: #f8f9fb;
      font-size: 0.75rem;
      font-weight: 600;
      padding: 6px 10px;
      border-bottom: 1px solid #e4e8ee;
      display: flex;
      justify-content: space-between;
      align-items: center;
    }
    .img-card img {
      width: 100%;
      display: block;
    }
    .download-link {
      color: #4a90d9;
      font-size: 0.7rem;
      text-decoration: none;
    }
    .download-link:hover { text-decoration: underline; }

    /* ── DE table wrapper ── */
    .de-table-wrapper { overflow-x: auto; }
    table.de-table { width: 100% !important; font-size: 0.82rem; }
    table.de-table thead th { background: #f0f2f5; }

    /* ── Responsive ── */
    @media (max-width: 900px) {
      .card, .toc { margin-left: 16px; margin-right: 16px; }
      .img-grid.cols-3 { grid-template-columns: 1fr 1fr; }
    }
    @media (max-width: 600px) {
      .img-grid.cols-3, .img-grid.cols-2 { grid-template-columns: 1fr; }
    }
  </style>
</head>
<body>

<!-- ── Page header ──────────────────────────────────────────────────── -->
<div class="page-header">
  <h1>Disease Subcluster Report</h1>
  <p>Tissue: <strong>{{ tissue }}</strong> &nbsp;·&nbsp; {{ subclusters | length }} subcluster(s) &nbsp;·&nbsp; Generated {{ generated_at }}</p>
</div>

<!-- ── Table of contents ────────────────────────────────────────────── -->
<div class="toc">
  <h2>Subclusters</h2>
  <ol>
    {% for sc in subclusters %}
    <li><a href="#{{ sc.anchor }}">{{ sc.label }}</a></li>
    {% endfor %}
  </ol>
</div>

<!-- ── Subcluster cards ─────────────────────────────────────────────── -->
{% for sc in subclusters %}
<div class="card" id="{{ sc.anchor }}">
  <div class="card-header" onclick="toggleCard(this)">
    <div>
      <h2>{{ sc.label }} <span class="badge">{{ sc.disease }}</span></h2>
    </div>
    <span class="chevron">▾</span>
  </div>
  <div class="card-body">

    <!-- Stats -->
    <div class="section-label">Summary statistics</div>
    <div class="stats-grid">
      <div class="stat-box">
        <div class="label">Total cells</div>
        <div class="value">{{ sc.stats.n_total }}</div>
      </div>
      <div class="stat-box">
        <div class="label">Disease cells</div>
        <div class="value">{{ sc.stats.n_disease }}</div>
      </div>
      <div class="stat-box">
        <div class="label">Healthy cells</div>
        <div class="value">{{ sc.stats.n_healthy }}</div>
      </div>
      <div class="stat-box">
        <div class="label">Fold enrichment</div>
        <div class="value">{{ sc.stats.fold_enrichment }}</div>
      </div>
      <div class="stat-box">
        <div class="label">FDR p-value</div>
        <div class="value">{{ sc.stats.fdr_pval }}</div>
      </div>
      <div class="stat-box">
        <div class="label">Cell type</div>
        <div class="value">{{ sc.stats.cell_type }}</div>
      </div>
    </div>

    <!-- Per-disease breakdown -->
    {% if sc.disease_breakdown %}
    <div class="section-label">Per-disease breakdown</div>
    <table class="breakdown-table">
      <thead>
        <tr>
          <th>Disease</th>
          <th>Cells in subcluster</th>
          <th>% of subcluster</th>
          <th>Fold enrichment</th>
          <th>p-value</th>
          <th>FDR</th>
        </tr>
      </thead>
      <tbody>
        {% for row in sc.disease_breakdown %}
        <tr>
          <td>{{ row.disease }}</td>
          <td>{{ row.n_cells }}</td>
          <td>{{ row.pct }}</td>
          <td>{{ row.fold }}</td>
          <td>{{ row.pval }}</td>
          <td>{{ row.fdr }}</td>
        </tr>
        {% endfor %}
      </tbody>
    </table>
    {% endif %}

    <!-- UMAP panels -->
    <div class="section-label">UMAP embeddings</div>
    <div class="img-grid cols-3">
      {% if sc.umap_celltype_b64 %}
      <div class="img-card">
        <div class="img-title">
          Cell type
          <a class="download-link" href="data:image/png;base64,{{ sc.umap_celltype_b64 }}" download="{{ sc.anchor }}_umap_celltype.png">⬇ download</a>
        </div>
        <img src="data:image/png;base64,{{ sc.umap_celltype_b64 }}" alt="UMAP cell type" />
      </div>
      {% endif %}
      {% if sc.umap_disease_b64 %}
      <div class="img-card">
        <div class="img-title">
          Disease condition
          <a class="download-link" href="data:image/png;base64,{{ sc.umap_disease_b64 }}" download="{{ sc.anchor }}_umap_disease.png">⬇ download</a>
        </div>
        <img src="data:image/png;base64,{{ sc.umap_disease_b64 }}" alt="UMAP disease" />
      </div>
      {% endif %}
      {% if sc.umap_highlight_b64 %}
      <div class="img-card">
        <div class="img-title">
          Subcluster highlight
          <a class="download-link" href="data:image/png;base64,{{ sc.umap_highlight_b64 }}" download="{{ sc.anchor }}_umap_highlight.png">⬇ download</a>
        </div>
        <img src="data:image/png;base64,{{ sc.umap_highlight_b64 }}" alt="UMAP highlight" />
      </div>
      {% endif %}
    </div>

    <!-- Volcano + Dotplot -->
    <div class="section-label">Differential expression &amp; functional enrichment</div>
    <div class="img-grid cols-2">
      {% if sc.volcano_b64 %}
      <div class="img-card">
        <div class="img-title">
          Volcano plot
          <a class="download-link" href="data:image/png;base64,{{ sc.volcano_b64 }}" download="{{ sc.anchor }}_volcano.png">⬇ download</a>
        </div>
        <img src="data:image/png;base64,{{ sc.volcano_b64 }}" alt="Volcano plot" />
      </div>
      {% endif %}
      {% if sc.dotplot_b64 %}
      <div class="img-card">
        <div class="img-title">
          Functional enrichment
          <a class="download-link" href="data:image/png;base64,{{ sc.dotplot_b64 }}" download="{{ sc.anchor }}_enrichment.png">⬇ download</a>
        </div>
        <img src="data:image/png;base64,{{ sc.dotplot_b64 }}" alt="Enrichment dotplot" />
      </div>
      {% endif %}
    </div>

    <!-- DE table -->
    {% if sc.de_records %}
    <div class="section-label">Differential expression table</div>
    <div class="de-table-wrapper">
      <table id="de-{{ sc.anchor }}" class="de-table display" style="width:100%">
        <thead>
          <tr>
            {% for col in sc.de_columns %}
            <th>{{ col }}</th>
            {% endfor %}
          </tr>
        </thead>
        <tbody>
          {% for row in sc.de_records %}
          <tr>
            {% for val in row %}
            <td>{{ val }}</td>
            {% endfor %}
          </tr>
          {% endfor %}
        </tbody>
      </table>
    </div>
    {% else %}
    <p style="color:#888; font-size:0.85rem;">No DE results available for this subcluster.</p>
    {% endif %}

  </div><!-- /card-body -->
</div><!-- /card -->
{% endfor %}

<!-- ── Scripts (DataTables inlined) ─────────────────────────────────── -->
<script>
{{ datatables_js }}
</script>

<script>
  // Initialise all DE tables
  document.querySelectorAll("table.de-table").forEach(function(tbl) {
    new DataTable(tbl, {
      pageLength: 25,
      lengthMenu: [10, 25, 50, 100],
      order: [],
      scrollX: true,
    });
  });

  // Toggle collapsible cards
  function toggleCard(header) {
    var body = header.nextElementSibling;
    var collapsed = header.classList.toggle("collapsed");
    body.classList.toggle("hidden", collapsed);
  }
</script>

</body>
</html>
